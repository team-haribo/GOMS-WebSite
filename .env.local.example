# ─────────────────────────────────────────────────────────
# GOMS-Web :: environment variables
# 이 파일을 .env.local로 복사한 뒤 값을 채워넣으세요.
# ─────────────────────────────────────────────────────────

# GitHub Personal Access Token (classic)
# Scope: read:org
# 발급: https://github.com/settings/tokens
GITHUB_TOKEN=

# ─── Admin 계정 ──────────────────────────────────────────
ADMIN_ID=
ADMIN_PASSWORD=
# 세션 쿠키 서명용 시크릿 (랜덤 긴 문자열). 유출되면 새로 생성하세요.
ADMIN_SESSION_SECRET=

# ─── Google OAuth (지원자 @gsm.hs.kr 검증용) ───────────
# Google Cloud Console → API & Services → Credentials → OAuth 2.0 Client ID
# Authorized JavaScript origins에 http://localhost:3000 및
# 배포 도메인(예: https://your-app.vercel.app)을 모두 추가하세요.
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ─── Supabase (데이터 저장) ──────────────────────────────
# Supabase 프로젝트 생성 후 Project Settings → API 에서 값을 복사하세요.
# SERVICE_ROLE_KEY는 절대 클라이언트에 노출하지 마세요 (서버 전용).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
